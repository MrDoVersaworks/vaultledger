# Database
DATABASE_URL=your_neon_postgresql_connection_string

# Auth
JWT_ACCESS_SECRET=your_64_char_hex_access_secret
JWT_REFRESH_SECRET=your_64_char_hex_refresh_secret

# Encryption (AES-256-GCM for user API keys)
AES_ENCRYPTION_KEY=your_64_char_hex_encryption_key

# Server
PORT=5002
NODE_ENV=development
CORS_ORIGIN=http://localhost:3002
